{
  "name": "@allourthings/cli",
  "version": "0.5.1",
  "description": "AllOurThings CLI — manage your personal inventory from the terminal.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matt-harding/allourthings-mcp.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "allourthings": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@allourthings/core": "^0.1.10",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
