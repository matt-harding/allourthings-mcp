{
  "name": "@allourthings/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for All Our Things — AI-powered household inventory",
  "type": "module",
  "files": ["dist"],
  "bin": {
    "allourthings-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
